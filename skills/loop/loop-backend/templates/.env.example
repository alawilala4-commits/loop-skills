# Template: Environment Configuration (.env.example)
# Usage: Copy to .env & fill in actual values
# DO NOT commit .env to git (add to .gitignore)

# ═══════════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════════
NODE_ENV=development
APP_NAME=MyApp
APP_PORT=3000
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════
# DATABASE (PostgreSQL)
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://user:password@localhost:5432/appdb
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=appdb
DB_SSL=false

# ═══════════════════════════════════════════════════════════════
# CACHE (Redis)
# ═══════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ═══════════════════════════════════════════════════════════════
# AUTHENTICATION & SECURITY
# ═══════════════════════════════════════════════════════════════
JWT_SECRET=your-secret-key-here-min-32-chars
JWT_EXPIRY=7d
SESSION_SECRET=session-secret-key
CORS_ORIGIN=http://localhost:3000

# ═══════════════════════════════════════════════════════════════
# EXTERNAL SERVICES
# ═══════════════════════════════════════════════════════════════
# Email (Gmail, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=app-password
SMTP_FROM=noreply@example.com

# API Keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...
GITHUB_TOKEN=ghp_...
OPENAI_API_KEY=sk-...

# ═══════════════════════════════════════════════════════════════
# MONITORING & LOGGING
# ═══════════════════════════════════════════════════════════════
SENTRY_DSN=https://...@sentry.io/...
DATADOG_API_KEY=
NEW_RELIC_LICENSE_KEY=

# ═══════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════
FEATURE_NEW_DASHBOARD=false
FEATURE_BETA_API=false
FEATURE_EMAIL_NOTIFICATIONS=true

# ═══════════════════════════════════════════════════════════════
# DEPLOYMENT
# ═══════════════════════════════════════════════════════════════
ENVIRONMENT=development
DEPLOYMENT_REGION=us-east-1
DEPLOYMENT_ROLLOUT=10

# NOTES:
# 1. Copy this file to .env and fill in actual values
# 2. Never commit .env to version control
# 3. Use different values for dev/staging/production
# 4. For secrets, use secure vault (HashiCorp Vault, AWS Secrets, etc.)
# 5. Rotate secrets regularly
