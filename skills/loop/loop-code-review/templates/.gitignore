# Template: .gitignore (Node.js + Python + General)
# Usage: Copy to root of repository

# ═══════════════════════════════════════════════════════════════
# ENVIRONMENT & SECRETS
# ═══════════════════════════════════════════════════════════════
.env
.env.local
.env.*.local
.env.production
secrets/
credentials/
*.pem
*.key

# ═══════════════════════════════════════════════════════════════
# NODE.JS
# ═══════════════════════════════════════════════════════════════
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
dist/
build/
.next/
out/

# ═══════════════════════════════════════════════════════════════
# PYTHON
# ═══════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/

# ═══════════════════════════════════════════════════════════════
# IDE & EDITORS
# ═══════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace
.vim
.vimrc

# ═══════════════════════════════════════════════════════════════
# LOGS & TEMPORARY FILES
# ═══════════════════════════════════════════════════════════════
logs/
*.log
tmp/
temp/
*.tmp
*.bak
*.swp

# ═══════════════════════════════════════════════════════════════
# DATABASE & CACHE
# ═══════════════════════════════════════════════════════════════
*.db
*.sqlite
*.sqlite3
.redis/
data/
cache/

# ═══════════════════════════════════════════════════════════════
# DOCKER
# ═══════════════════════════════════════════════════════════════
docker-compose.override.yml
.dockerignore

# ═══════════════════════════════════════════════════════════════
# OS SPECIFIC
# ═══════════════════════════════════════════════════════════════
Thumbs.db
.DS_Store
.AppleDouble
.LSOverride
._*

# ═══════════════════════════════════════════════════════════════
# BUILD ARTIFACTS
# ═══════════════════════════════════════════════════════════════
*.o
*.a
*.lib
*.so
*.dylib
*.dll
*.exe
